# All secrets/credentials needed by any e2e case live here in a single file.
# LLM-specific knobs (LLM_DEFAULT_MODEL, USE_DATAROBOT_LLM_GATEWAY, WORKFLOW_FILE,
# LLM, AGENT) are NOT placed here — they come from cases/<file>.yaml and from the
# matrix combination selected for the run.

# DataRobot platform
# Values for buzok-ci-agents@datarobot.com on US prod:
# https://start.1password.com/open/i?a=SNW6QKQ365EQTAV726YE6K4S24&v=jreitiqnr2da7l2itgt5lflm2e&i=qxlkoduit6bi7u3s23n7jik2s4&h=datarobot.1password.com
DATAROBOT_ENDPOINT="https://app.datarobot.com/api/v2"
DATAROBOT_API_TOKEN=
DATAROBOT_USER_ID=
SESSION_SECRET_KEY=

# MCP and deployed-LLM tests
MCP_DEPLOYMENT_ID=
LLM_DEPLOYMENT_ID=
EMOTION_CLASSIFIER_DEPLOYMENT_ID=
OOTB_CUSTOM_METRIC_ENDPOINT=

# External LLM tests (Azure OpenAI)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION="2025-03-01-preview"

# OTel
# Route OTel spans to the in-process mock collector the e2e tests bind (see
# dragent_tests/conftest.py::otel_collector and helpers.py OTEL_* constants).
# MLOPS_DEPLOYMENT_ID unlocks the SDK TracerProvider bootstrap in
# datarobot_genai.core.telemetry.agent.instrument(), without which the
# datarobot_otel_conventions spans (gen_ai.prompt / gen_ai.completion) are
# no-ops. The endpoint/headers must match helpers.OTEL_* exactly.
MLOPS_DEPLOYMENT_ID=e2e-test
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/otel
OTEL_EXPORTER_OTLP_HEADERS=X-DataRobot-Api-Key=e2e-otel-token,X-DataRobot-Entity-Id=deployment-e2e-test
