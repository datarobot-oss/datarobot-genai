# All secrets/credentials needed by any e2e case live here in a single file.
# LLM-specific knobs (LLM_DEFAULT_MODEL, USE_DATAROBOT_LLM_GATEWAY, WORKFLOW_FILE,
# LLM, AGENT) are NOT placed here — they come from cases/<file>.yaml and from the
# matrix combination selected for the run.

# DataRobot platform
# Values for buzok-ci-agents@datarobot.com on US prod:
# https://start.1password.com/open/i?a=SNW6QKQ365EQTAV726YE6K4S24&v=jreitiqnr2da7l2itgt5lflm2e&i=qxlkoduit6bi7u3s23n7jik2s4&h=datarobot.1password.com
DATAROBOT_ENDPOINT="https://app.datarobot.com/api/v2"
DATAROBOT_API_TOKEN=
DATAROBOT_USER_ID=
SESSION_SECRET_KEY=

# MCP and deployed-LLM tests
MCP_DEPLOYMENT_ID=
LLM_DEPLOYMENT_ID=
EMOTION_CLASSIFIER_DEPLOYMENT_ID=
OOTB_CUSTOM_METRIC_ENDPOINT=

# External LLM tests (Azure OpenAI)
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION="2025-03-01-preview"

# DataRobot Memory Service e2e (cases/memory.yaml)
# When E2E_PROVISION_MEMORY_SPACE=true the runner creates a MemorySpace automatically.
# Set AGENT_MEMORY_SPACE_ID manually only when reusing an existing space with --no-server.
# AGENT_MEMORY_SPACE_ID=
