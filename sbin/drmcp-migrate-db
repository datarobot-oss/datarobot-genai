"""
drmcp-migrate-db — standalone migration runner for the MCP server.

Mirrors the pattern used by the DataRobot notebooks service and monolith
(sbin/datarobot-migrate-db).  When the internal dr-mongo-migrations package
is available it can replace this runner; the migration modules expose the
same analyze/run/rollback interface either way.

Environment variables
---------------------
MONGO_URI                   MongoDB connection string (required)
DB_NAME                     Database name (default: drmcp)
MIGRATION_DATABASE_NAME     Database that tracks applied migrations
                            (default: same as DB_NAME)
MIGRATION_COLLECTION_NAME   Collection that records applied migrations
                            (default: drmcp_migrations)
MIGRATIONS_DIR              Directory containing migration_*.py files
                            (default: db_migrations/ next to this script)
INDEX_CONFIG                Path to mongo_indexes.json
                            (default: config/mongo_indexes.json next to script root)

Usage
-----
  # Run all pending migrations
  MONGO_URI=mongodb://localhost:27017 ./sbin/drmcp-migrate-db

  # Dry-run (analyze only, no writes)
  MONGO_URI=mongodb://localhost:27017 ./sbin/drmcp-migrate-db --analyze
"""

from __future__ import annotations

import argparse
import asyncio
import importlib.util
import json
import logging
import os
import sys
from datetime import datetime
from datetime import timezone
from pathlib import Path

logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
logger = logging.getLogger("drmcp-migrate-db")

# ---------------------------------------------------------------------------
# Resolve repo root relative to this script (sbin/ sits at repo root)
# ---------------------------------------------------------------------------
SCRIPT_DIR = Path(__file__).resolve().parent
REPO_ROOT = SCRIPT_DIR.parent


def _env(name: str, default: str | None = None) -> str:
    val = os.environ.get(name, default)
    if val is None:
        logger.error("Required environment variable %s is not set.", name)
        sys.exit(1)
    return val


async def _apply_indexes(db: object, index_config_path: Path) -> None:
    """Apply indexes declared in mongo_indexes.json."""
    if not index_config_path.exists():
        logger.warning("Index config not found at %s — skipping index creation.", index_config_path)
        return

    with index_config_path.open() as fh:
        config: dict = json.load(fh)

    for collection_name, indexes in config.items():
        collection = db[collection_name]
        existing = {idx["name"] async for idx in collection.list_indexes()}
        for idx_def in indexes:
            idx_name = idx_def["name"]
            if idx_name in existing:
                logger.info("Index %s on %s already exists — skipping.", idx_name, collection_name)
                continue
            key = list(idx_def["key"].items())
            opts = {k: v for k, v in idx_def.items() if k not in ("key",)}
            await collection.create_index(key, **opts)
            logger.info("Created index %s on %s.", idx_name, collection_name)


def _load_migration_modules(migrations_dir: Path) -> list[tuple[str, object]]:
    """Load migration_*.py files from *migrations_dir* sorted by filename."""
    modules = []
    for path in sorted(migrations_dir.glob("migration_*.py")):
        spec = importlib.util.spec_from_file_location(path.stem, path)
        if spec is None or spec.loader is None:
            continue
        mod = importlib.util.module_from_spec(spec)
        spec.loader.exec_module(mod)  # type: ignore[union-attr]
        modules.append((path.stem, mod))
    return modules


async def _run_migrations(
    app_db: object,
    ledger_db: object,
    ledger_collection_name: str,
    migrations: list[tuple[str, object]],
    analyze_only: bool,
) -> None:
    ledger = ledger_db[ledger_collection_name]

    applied = {
        doc["name"]
        async for doc in ledger.find({}, {"name": 1})
    }

    for name, mod in migrations:
        if name in applied:
            logger.info("Migration %s already applied — skipping.", name)
            continue

        if analyze_only:
            result = mod.analyze(app_db)
            logger.info("ANALYZE %s: %s", name, result)
            continue

        logger.info("Running migration %s …", name)
        success = await mod.run(app_db)
        if not success:
            logger.error("Migration %s reported failure — stopping.", name)
            sys.exit(1)

        await ledger.insert_one(
            {
                "name": name,
                "applied_at": datetime.now(tz=timezone.utc),
            }
        )
        logger.info("Migration %s applied successfully.", name)


async def main(analyze_only: bool) -> None:
    try:
        from motor.motor_asyncio import AsyncIOMotorClient
    except ImportError:
        logger.error(
            "motor is not installed. Install it with: pip install motor"
        )
        sys.exit(1)

    mongo_uri = _env("MONGO_URI")
    db_name = _env("DB_NAME", "drmcp")
    migration_db_name = os.environ.get("MIGRATION_DATABASE_NAME", db_name)
    ledger_collection = os.environ.get("MIGRATION_COLLECTION_NAME", "drmcp_migrations")
    migrations_dir = Path(os.environ.get("MIGRATIONS_DIR", str(REPO_ROOT / "db_migrations")))
    index_config_path = Path(
        os.environ.get("INDEX_CONFIG", str(REPO_ROOT / "config" / "mongo_indexes.json"))
    )

    client = AsyncIOMotorClient(mongo_uri)
    try:
        app_db = client[db_name]
        ledger_db = client[migration_db_name]

        logger.info("Connected to MongoDB. DB=%s, ledger=%s.%s", db_name, migration_db_name, ledger_collection)

        if not analyze_only:
            logger.info("Applying indexes from %s …", index_config_path)
            await _apply_indexes(app_db, index_config_path)

        migrations = _load_migration_modules(migrations_dir)
        logger.info("Found %d migration module(s) in %s.", len(migrations), migrations_dir)

        await _run_migrations(
            app_db=app_db,
            ledger_db=ledger_db,
            ledger_collection_name=ledger_collection,
            migrations=migrations,
            analyze_only=analyze_only,
        )

        logger.info("Done.")
    finally:
        client.close()


if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Run drmcp MongoDB migrations.")
    parser.add_argument(
        "--analyze",
        action="store_true",
        help="Dry-run: print what each migration would do without applying changes.",
    )
    args = parser.parse_args()
    asyncio.run(main(analyze_only=args.analyze))
